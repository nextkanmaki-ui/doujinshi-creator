{
  "version": 2,
  "builds": [
    {
      "src": "deploy_package/api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "deploy_package/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/deploy_package/api/$1"
    },
    {
      "src": "/",
      "dest": "/deploy_package/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/deploy_package/public/$1"
    }
  ]
}
