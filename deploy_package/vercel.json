{
  "version": 2,
  "functions": {
    "api/claude.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/claude",
      "dest": "/api/claude.js"
    },
    {
      "src": "/",
      "dest": "/deploy_package/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/deploy_package/public/$1"
    }
  ]
}
